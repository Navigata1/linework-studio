# ─────────────────────────────────────────────────────────────
# Brain Loft Studios — environment
# Copy to .env.local and fill in. EVERYTHING here is OPTIONAL:
# the app runs and deploys with zero secrets, then lights up
# feature-by-feature as you add keys.
# ─────────────────────────────────────────────────────────────

# AI drafting (photo descriptions + dossier synthesis).
# EITHER key works — OpenRouter is checked first (free models supported!),
# then Anthropic. Without both, tools fall back to deterministic templates.
# Free vision model example: OPENROUTER_MODEL=qwen/qwen2.5-vl-72b-instruct:free
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
ANTHROPIC_API_KEY=

# Supabase — persistence for intake requests, reports, dossiers.
# Without it, submissions are logged and returned but not stored.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Clerk — studio authentication gate.
# Without it, the studio is open (single-user local mode).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Resend — intake email notifications.
# Without it, intake is stored/logged but no email is sent.
RESEND_API_KEY=
STUDIO_NOTIFY_EMAIL=

# Regrid / parcel API — authoritative parcel geometry for the dossier.
# Without it, the dossier uses county deep-links + AI research.
REGRID_API_TOKEN=

# Public site config
NEXT_PUBLIC_STUDIO_NAME=Brain Loft Studios
NEXT_PUBLIC_STUDIO_DOMAIN=brainloftstudios.com
